# Local Apps Script project configs — contain script/container IDs.
# .clasp.json      -> the private app (plain `clasp push`)
# .clasp.public.json -> the public forkable template (`./push-public.sh`)
.clasp.json
.clasp.public.json

# Internal dev notes — contain the real deployment IDs and owner email
AGENT.md

# Vocab data with dictionary-derived glosses — kept local, not redistributed.
# The app does not need these to run (built-in starter deck + your Google Sheet).
nl_b1b2_glossed.csv
nl_b1b2_cards.csv

# OS / editor / tooling cruft
.DS_Store
*.log
node_modules/

# Transient patch files (e.g. from cloud plan runs)
*.patch
